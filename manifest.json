{
  "manifest_version": 3,
  "name": "Google Enhanced",
  "version": "2.1.1",
  "description": "Removes doodles/share from Google homepage and replaces Chrome New Tab with a clean customizable page.",
  "permissions": [
    "topSites",
    "favicon",
    "storage",
    "identity",
    "identity.email",
    "alarms",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Google Enhanced",
    "default_popup": "popup.html"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/*",
        "*://www.google.co.uk/*",
        "*://www.google.ca/*",
        "*://www.google.com.au/*",
        "*://www.google.co.in/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://www.youtube.com/*"
      ],
      "js": ["youtube.js"],
      "run_at": "document_start"
    }
  ]
}
